@page "/versions"
@rendermode InteractiveServer
@using Ember.Scripting
@inject ISccriptManagerDeleteAfter ScriptManager

<PageTitle>API Versions</PageTitle>

<div class="page-container">
    <div class="top-bar mb-4">
        <h2>API Versions</h2>
        <p class="text-muted m-0">Manage API versions and compatibility</p>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Loading API versions...</p>
        </div>
    }
    else if (ApiVersionsData == null || !ApiVersionsData.Any())
    {
        <div class="empty-state">
            <i class="bi bi-layers"></i>
            <h4>No API versions found</h4>
            <p>There are currently no compiled script caches available.</p>
        </div>
    }
    else
    {
        <div class="api-versions-container">
            @* Order by API version descending so the newest is at the top *@
            @foreach (var versionGroup in ApiVersionsData.OrderByDescending(v => v.Key))
            {
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="bi bi-layer-forward me-2"></i> API Version @versionGroup.Key
                        </h5>
                        <span class="badge bg-light text-primary rounded-pill fs-6">
                            @versionGroup.Value.Count Script(s)
                        </span>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Script Name</th>
                                        <th>Compiled Date</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var cache in versionGroup.Value)
                                    {
                                        <tr>
                                            <td>
                                                <i class="bi bi-file-earmark-code text-primary me-2"></i>
                                                <strong>@(cache.CustomerScript?.ScriptName ?? "Unknown Script")</strong>
                                            </td>
                                            <td>@cache.CompilationDate.ToString("MM-dd HH:mm")</td>
                                            <td>
                                                @if (cache.CompilationSuccess)
                                                {
                                                    <span class="badge bg-success">Success</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger" title="@cache.CompilationErrors">Failed</span>
                                                }
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-outline-danger" title="Delete Cache"
                                                        @onclick="() => DeleteCache(cache.ScriptId, cache.ApiVersion)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private Dictionary<int, List<CompiledScripts>>? ApiVersionsData;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            // Fetch the dictionary from the backend
            ApiVersionsData = await ScriptManager.GetCachesForEachApiVersion();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading API versions: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task DeleteCache(Guid scriptId, int apiVersion)
    {
        try
        {
            await ScriptManager.DeleteScriptCache(scriptId, apiVersion);
            await LoadData(); // Refresh the UI after deletion
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to delete cache: {ex.Message}");
        }
    }
}