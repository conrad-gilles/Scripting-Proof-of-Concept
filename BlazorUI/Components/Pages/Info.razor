@page "/info"
<PageTitle>Info - Ember</PageTitle>

<div class="top-bar mb-3">
    <h2>Information & Resources</h2>
</div>

<div class="row">
    <!-- Project Description Card -->
    <div class="col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-info-circle"></i>
                About Ember Scripting Manager
            </div>
            <div class="card-body">
                <p>
                    Ember Scripting Manager is a dynamic C# scripting execution framework designed to compile, manage,
                    and execute scripts across multiple instances.
                </p>
                <div class="mt-4">
                    <h6>Tech Stack</h6>
                    <span class="badge bg-primary mb-1">.NET 9</span>
                    <span class="badge bg-primary mb-1">Blazor Server</span>
                    <span class="badge bg-primary mb-1">Roslyn Compiler</span>
                    <span class="badge bg-primary mb-1">Entity Framework Core</span>
                    <span class="badge bg-primary mb-1">PostgreSQL</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Links Card -->
    <div class="col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-link-45deg"></i>
                Links & Documentation
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    <a href="https://github.com/yourusername/ember-scripting" target="_blank"
                           class="list-group-item list-group-item-action d-flex align-items-center p-3">
                        <i class="bi bi-github fs-4 me-3"></i>
                        <div>
                            <h6 class="mb-0">GitHub Repository</h6>
                            <small class="text-muted">Source code, issue tracking, and releases</small>
                        </div>
                    </a>
                    <a href="/docs" target="_blank"
                           class="list-group-item list-group-item-action d-flex align-items-center p-3">
                        <i class="bi bi-book fs-4 me-3 text-info"></i>
                        <div>
                            <h6 class="mb-0">Documentation</h6>
                            <small class="text-muted">API references, script examples, and tutorials</small>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>