@page "/create"
@rendermode InteractiveServer
@using System.Reflection
@using System.Text.RegularExpressions
@using System.Threading.Tasks
@using BlazorUI.Helpers
@using BlazorUI.Services
@using Ember.Scripting
@* @using Ember.Scripting.ScriptMethods *@
@using Ember.Simulation
@using Ember.Scripting.Compilation

<PageTitle>Create Script</PageTitle>

<div class="d-flex flex-column" style="height: calc(100vh - 40px); overflow: hidden;">
    <!-- Top bar with action buttons -->
    <div class="top-bar d-flex justify-content-between align-items-center mb-3 flex-shrink-0">
        <h2 class="mb-0">Create New Script</h2>
        <div class="d-flex gap-2">
 
            <select class="form-select" style="width: auto; min-width: 180px;" @bind="SelectedTemplate"
                    @bind:after="OnTemplateChanged" disabled="@(_editorHelper?.IsBusy ?? false)">
                <option value="" disabled>Select Template</option>
                @foreach (var method in PredefinedTemplates.Keys)
                {
                    <option value="@method">@method</option>
                }
            </select>
            <!-- No need to pass newScript boolean, the helper knows its own state -->
            <button class="btn btn-outline-info" @onclick="async () => await Validate()!"
                    disabled="@(_editorHelper?.IsBusy ?? false)">
                <i class="bi bi-check-circle"></i> Validate
            </button>
            @* <button class="btn btn-outline-warning" @onclick="() => _editorHelper?.Compile(null)!"
                    disabled="@(_editorHelper?.IsBusy ?? false)">
                <i class="bi bi-hammer"></i> Compile
            </button> *@
            <button class="btn btn-outline-primary" @onclick="async () => await Execute()"
                    disabled="@(_editorHelper?.IsBusy ?? false)">
                <i class="bi bi-play-circle"></i> Execute
            </button>
            <select class="form-select" style="width: auto; min-width: 180px;" @bind="SelectedMethod"
                    disabled="@(_editorHelper?.IsBusy ?? false)">
                <option value="" disabled>Select Method</option>
                @foreach (var method in PredefinedMethods)
                {
                    <option value="@method">@method</option>
                }
            </select>
            <button class="btn btn-success" @onclick="async () => await _editorHelper?.CreateAndInsert()!"
                    disabled="@(_editorHelper?.IsBusy ?? false)">
                <i class="bi bi-save"></i> Create
            </button>
            <a href="scripts" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <!-- We bind it to the _editor variable using @ref -->
    <MonacoEditor @ref="_editor" InitialCode="@DefaultScript"
                  OnCodeChanged="() => _editorHelper?.SetErrorsInEditorAsync()!" />


    <div style="height: @(Console.IsExpanded ? "300px" : "40px"); transition: height 0.3s ease-in-out; flex-shrink: 0;">
    </div>
</div>

<FakeTerminal />
<Popup @ref="myPopup" />

@code {
    private IScriptManagerBaseExtended ScriptManager => ScriptManagerAccessor.Current;
    private ScriptManager EmberInternalFacade => EmberInternalFacadeAccessor.Current;
    private MonacoEditor _editor = default!;
    private Popup myPopup = default!;
    private MonacoEditorHelper _editorHelper = default!;

    @* private EmberMethods rm = new EmberMethods(ScriptManager); *@
    private string SelectedMethod = "";
    private string SelectedTemplate = "";
    private List<string> PredefinedMethods = ["Standard"];
    private Dictionary<string, string> PredefinedTemplates = [];
    public string DefaultScript = GetTemplate();

    protected override async Task OnInitializedAsync()
    {
        PredefinedTemplates = await EmberMethods.GetScriptTemplates();
    }

    @* public static string GetTemplate()
    {
        string path = Path.GetFullPath(Path.Combine(
             AppDomain.CurrentDomain.BaseDirectory,
             "..", "..", "..",
             "src", "ScriptTemplate.cs"
         ));
        return EmberMethods.CreateStringFromCsFile(path);
    } *@

    public async Task Validate()
    {
        ValidationRecord? vali = await _editorHelper.Validate();
        if (vali != null)
        {
            List<string> methods = ["Standard"];
            if (vali.methods != null)
            {
                foreach (var method in vali.methods)
                {
                    methods.Add(method.Name);
                }

            }
            PredefinedMethods = methods;
        }
        PredefinedTemplates = await EmberMethods.GetScriptTemplates();
    }
    public async Task Execute()
    {
        string? methodName = null;
        if (SelectedMethod != "Standard" && SelectedMethod != "")
        {
            methodName = SelectedMethod;
        }
        await _editorHelper?.Execute(methodName: methodName)!;
    }
    public static string GetTemplate()
    {
        // The format is: DefaultNamespace.FolderName.FileName.Extension
        var resourceName = "BlazorUI.src.ScriptTemplate.cs";
        var assembly = Assembly.GetExecutingAssembly();

        using (Stream stream = assembly.GetManifestResourceStream(resourceName)!)
        {
            if (stream == null)
            {
                return "// Error: Could not find embedded ScriptTemplate.cs";
            }

            using (StreamReader reader = new StreamReader(stream))
            {
                return reader.ReadToEnd();
            }
        }
    }
    public async Task OnTemplateChanged()
    {
        string sc = PredefinedTemplates[SelectedTemplate];
        await _editor.SetValueAsync(sc);
    }

    // YOU MUST HAVE THIS to initialize the helper!
    protected override void OnAfterRender(bool firstRender)
    {
        try
        {
            if (firstRender && _editor != null)
            {
                _editorHelper = new MonacoEditorHelper(ScriptManagerAccessor.Current, EmberInternalFacadeAccessor.Current, _editor,
Console, myPopup)
                {
                    ScriptName = "New Script",
                    CurrentScriptId = Guid.Empty // Explicitly set to empty so the helper knows it's new
                };
                StateHasChanged();
            }
        }
        catch (Exception e)
        {
            Console.LogException(e);
            myPopup.CreateErrorPopup(e.GetType().Name, e.Message);
        }
    }
}