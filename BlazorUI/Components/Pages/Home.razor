<Popup @ref="myPopup" />

@code {
    private IScriptManagerDeleteAfter ScriptManager => ScriptManagerAccessor.Current;
    private Popup myPopup = default!;
    private bool _isLoading = true;
    private bool _isWorking = false;
    private int _totalScripts = 0;
    private int _compiledScripts = 0;
    private int _pendingScripts = 0;
    @* private int totalExecutions = 0; *@

    private int _currentEmberVersionApi = 0; //todo weird imp

    private bool _showErrorPopup = false;
    private string _errorMessage = string.Empty;
    private string _errorDetails = string.Empty;

    private List<CustomerScript> _customerScripts = [];
    private List<CustomerScript> _recentScripts = []; // ADD THIS LINE
    private List<EmberInstance>? emberInstances;

    // This lifecycle method runs when the page loads
    protected override async Task OnInitializedAsync()
    {
        await LoadDashBoardData();
        await LoadEmberInstances();
    }
    private async Task LoadEmberInstances()
    {
        @* try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            // Order by the most recently active instances
            emberInstances = await context.EmberInstances
                .OrderByDescending(e => e.LastHeartbeat)
                .ToListAsync();
        }
        catch (Exception e)
        {
            Console.LogException(e);
            myPopup.CreateErrorPopup(e.GetType().Name, e.Message);
        } *@
    }
    // Helper method for the "Last heartbeat: X ago" text
    private string GetTimeAgo(DateTime dateTime)
    {
        var timeSpan = DateTime.UtcNow - dateTime.ToUniversalTime();
    
        if (timeSpan.TotalSeconds < 60)
            return $"{(int)timeSpan.TotalSeconds} seconds ago";
        if (timeSpan.TotalMinutes < 60)
            return $"{(int)timeSpan.TotalMinutes} minutes ago";
        if (timeSpan.TotalHours < 24)
            return $"{(int)timeSpan.TotalHours} hours ago";
        
        return $"{(int)timeSpan.TotalDays} days ago";
    }
    private async Task TestUpdate()
    {
        try
        {
            await LoadDashBoardData();
            _totalScripts++;
            StateHasChanged();
        }
       
        catch (Exception e)
        {
            Console.LogException(e);
            myPopup.CreateErrorPopup(e.GetType().Name, e.Message);
        }
    }
    private async Task LoadDashBoardData()
    {
        try
        {
            EmberMethods em = new EmberMethods(ScriptManager);
            _currentEmberVersionApi = ScriptManager.GetRunningApiVersion();
            _customerScripts = await ScriptManager.ListScripts(includeCaches: true);
            _totalScripts = _customerScripts.Count();
            _compiledScripts = 0;
            _pendingScripts = 0;

            foreach (var script in _customerScripts)
            {
                List<int> versions = [];
                foreach (var cache in script.CompiledCaches)
                {
                    versions.Add(cache.ApiVersion);
                }
                if (versions.Contains(ScriptManager.GetRunningApiVersion()) == false)
                {
                    _pendingScripts++;
                }
            }
            _compiledScripts = _totalScripts - _pendingScripts;
            // ADD THESE LINES to populate the Recent Scripts table:
            // Order by ModifiedAt (or CreatedAt if ModifiedAt is null), descending, and take the top 5.
            _recentScripts = _customerScripts
                .OrderByDescending(s => s.ModifiedAt ?? s.CreatedAt ?? DateTime.MinValue)
                .Take(3)
                .ToList();

            StateHasChanged();
        }
      
        catch (Exception e)
        {
            Console.LogException(e);
            myPopup.CreateErrorPopup(e.GetType().Name, e.Message);
        }
    }

    private async Task HandleCompileAllScripts()
    {
        try
        {
            await ScriptManager.CompileAllScripts();
            await LoadDashBoardData();
        }
        catch (Exception e)
        {
            Console.LogException(e);
            myPopup.CreateErrorPopup(e.GetType().Name, e.Message);
        }
    }
    private async Task HandleCompileAllScriptsFromFolder()
    {
        try
        {
            _isWorking = true; //might have to call StateChange
            StateHasChanged();
            EmberMethods rm = new EmberMethods(ScriptManager);
            @* string path = @"C:\Users\Gilles\Desktop\UNI\Semester 6\Code\Codebase\Scripting-Proof-of-Concept\sandbox\src\Scripts";
*@

            string path = Path.GetFullPath(Path.Combine(
                AppDomain.CurrentDomain.BaseDirectory,
                "..", "..", "..", "..",
                "sandbox", "src", "Scripts"
            ));

            @* await rm.CompileAllScriptsInFolderAndSaveToDB(path, "Gilles", EmberMethods.GetEmberApiVersion()); *@
            await rm.CompileAllScriptsInFolderAndSaveToDB(userName: "Gilles", currentApiVersion:
EmberMethods.GetEmberApiVersion(), folderPath: path);

            _isWorking = false;
            StateHasChanged();

            await LoadDashBoardData();
        }
        catch (CompileAllScriptsInFolderException)
        {
            _isWorking = false;
            await LoadDashBoardData();
        }
        catch (Ember.Scripting.ScriptRepositoryException e)
        {
            _isWorking = false;
            _errorMessage = e.Message;
            _errorDetails = e.ToString();
            @* _showErrorPopup = true; *@
            myPopup.CreateErrorPopup(e.GetType().Name, e.Message);
            StateHasChanged();
            await LoadDashBoardData();
        }
        catch (Exception e)
        {
            _isWorking = false;
            @* Console.WriteLine(e.ToString()); *@
            Console.Log(e.Message);
            myPopup.CreateErrorPopup(e.GetType().Name, e.Message);
            await LoadDashBoardData();

            @* throw; //todo remove *@
        }

    }

    private void CloseErrorPopup()
    {
        try
        {
            _showErrorPopup = false;
            _errorMessage = string.Empty;
            _errorDetails = string.Empty;
        }
        
        catch (Exception e)
        {
            Console.LogException(e);
            myPopup.CreateErrorPopup(e.GetType().Name, e.Message);
        }
    }

    private async Task HandleClearAllCaches()
    {
        try
        {
            await ScriptManager.ClearAllCaches();
            await LoadDashBoardData();
        }
        catch (Exception e)
        {
            Console.LogException(e);
            myPopup.CreateErrorPopup(e.GetType().Name, e.Message);
        }
    }
    private async Task HandleDeleteAllScripts()
    {
        try
        {
            @* await ScriptManager.EnsureDeletedCreated(); *@
            await ScriptManager.DeleteAllData();
            await LoadDashBoardData();
        }
       
        catch (Exception e)
        {
            Console.LogException(e);
            myPopup.CreateErrorPopup(e.GetType().Name, e.Message);
        }
    }
}