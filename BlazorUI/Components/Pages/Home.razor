    <h2>Dashboard</h2>
    <div>
        <span class="badge bg-success">
            <span class="status-dot active"></span>
            System Online
        </span>
    </div>
</div> *@
<!-- Statistics Cards -->
<div class="row mb-4">
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="stat-card">
            <i class="bi bi-file-code-fill"></i>
            <h3>@totalScripts</h3>
            <p>Total Scripts</p>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="stat-card success">
            <i class="bi bi-check-circle-fill"></i>
            <h3>
                @compiledScripts
            </h3>
            <p>Compiled Scripts</p>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="stat-card warning">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <h3>@pendingScripts</h3>
            <p>Pending Compilation</p>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="stat-card info">
            <i class="bi bi-clock-history"></i>
            <h3>@(TotalExecutions.GetTotalExecutions())</h3>
            <p>Total Executions</p>
        </div>
    </div>
</div>
<!-- Add this below the <div class="row mt-4">
block in Home.razor -->
<div class="card mt-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>
            <i class="bi bi-clock-history"></i>
            Recent Scripts
        </span>
        <a href="/scripts" class="btn btn-sm btn-primary">
            View All
        </a>
    </div>
    <div class="card-body p-0">
        <div class="table-container">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Script Name</th>
                        <th>Type</th>
                        <th>API Version</th>
                        <th>Status</th>
                        <th>Last Modified</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var script in RecentScripts)
                    {
                        <tr>
                            <td class="ps-4">
                                <i class="bi bi-file-code text-primary"></i>
                                @script.ScriptName
                            </td>
                            <td>
                                @if (script.ScriptType != null && script.ScriptType.Contains("Action"))
                                {
                                    <span class="badge bg-info">Action</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Condition</span>
                                }
                            </td>
                            <td>v@(script.MinApiVersion)</td>
                            <td>
                                @if (script.CompiledCaches != null && script.CompiledCaches.Any(c => c.CompilationSuccess))
                                {
                                    <span class="badge bg-success">Compiled</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Pending</span>
                                }
                            </td>
                            <td>
                                @(script.ModifiedAt?.ToString("yyyy-MM-dd HH:mm") ?? script.CreatedAt?.ToString("yyyy-MM-dd                            HH:mm") ?? "N/A")
                            </td>
                            <td class="text-end pe-4">
                                <div class="action-buttons justify-content-end">
                                    <a href="/scripts" class="btn btn-sm btn-outline-primary btn-icon" title="View">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!RecentScripts.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-3">
                                No scripts found.
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>
    </div>
</div>
<div class="row mt-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-server"></i>
                Ember Instances Todo
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <span class="status-dot active"></span>
                        <strong>Instance-01 Todo</strong>
                    </div>
                    <span class="badge bg-primary">vWhatever (API v@(currentEmberVersionApi))</span>
                </div>
                <div class="progress">
                    <div class="progress-bar bg-success" style="width: 85%"></div>
                </div>
                <small class="text-muted">Last heartbeat: 30 seconds ago Todo</small>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-activity"></i>
                Quick Actions
            </div>
            <div class="card-body">
                <a href="/create" class="btn btn-primary w-100 mb-2">
                    <i class="bi bi-plus-circle"></i>
                    Create New Script
                </a>
                <button class="btn btn-outline-primary w-100 mb-2" @onclick="HandleCompileAllScripts"
                        disabled="@isWorking">
                    @if (isWorking)
                    {
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        <span>Compiling...</span>
                    }
                    else
                    {
                        <i class="bi bi-hammer"></i>
                        <span>Compile All Scripts</span>
                    }
                </button>
                <button class="btn btn-outline-primary w-100 mb-2" @onclick="HandleCompileAllScriptsFromFolder">
                    <i class="bi bi-hammer"></i>
                    <span>Compile Default Scripts From Folder</span>

                </button>
                <button class="btn btn-outline-danger w-100 mb-2" @onclick="HandleClearAllCaches">
                    <i class="bi bi-trash"></i>
                    Clear All Caches
                </button>
                <button class="btn btn-outline-danger w-100 mb-2" @onclick="HandleDeleteAllScripts">
                    <i class="bi bi-trash"></i>
                    Delete All Scripts
                </button>
            </div>
        </div>
    </div>
</div>



@code {
    private bool isLoading = true;
    private bool isWorking = false;
    private int totalScripts = 0;
    private int compiledScripts = 0;
    private int pendingScripts = 0;
    @* private int totalExecutions = 0; *@

    private int currentEmberVersionApi = 0; //todo weird imp

    private List<CustomerScript> CustomerScripts = [];
    private List<CustomerScript> RecentScripts = []; // ADD THIS LINE

    // This lifecycle method runs when the page loads
    protected override async Task OnInitializedAsync()
    {
        await LoadDashBoardData();
    }

    private async Task TestUpdate()
    {

        await LoadDashBoardData();
        totalScripts++;
        StateHasChanged();
    }
    private async Task LoadDashBoardData()
    {
        EmberMethods em = new EmberMethods(ScriptManager);
        currentEmberVersionApi = ScriptManager.GetRunningApiVersion();
        CustomerScripts = await ScriptManager.ListScripts(includeCaches: true);
        totalScripts = CustomerScripts.Count();
        compiledScripts = 0;

        foreach (var script in CustomerScripts)
        {
            List<int> versions = [];
            foreach (var cache in script.CompiledCaches)
            {
                versions.Add(cache.ApiVersion);
            }
            if (versions.Contains(ScriptManager.GetRunningApiVersion()) == false)
            {
                pendingScripts++;
            }
        }

        // ADD THESE LINES to populate the Recent Scripts table:
        // Order by ModifiedAt (or CreatedAt if ModifiedAt is null), descending, and take the top 5.
        RecentScripts = CustomerScripts
            .OrderByDescending(s => s.ModifiedAt ?? s.CreatedAt ?? DateTime.MinValue)
            .Take(3)
            .ToList();

        StateHasChanged();
    }

    private async Task HandleCompileAllScripts()
    {
        await ScriptManager.CompileAllScripts();
        await LoadDashBoardData();
    }
    private async Task HandleCompileAllScriptsFromFolder()
    {
        try
        {
            isWorking = true; //might have to call StateChange
            StateHasChanged();
            EmberMethods rm = new EmberMethods(ScriptManager);
            @* string path = @"C:\Users\Gilles\Desktop\UNI\Semester 6\Code\Codebase\Scripting-Proof-of-Concept\sandbox\src\Scripts"; *@

            string path = Path.GetFullPath(Path.Combine(
                AppDomain.CurrentDomain.BaseDirectory,
                "..", "..", "..", "..",
                "sandbox", "src", "Scripts"
            ));

            @* await rm.CompileAllScriptsInFolderAndSaveToDB(path, "Gilles", EmberMethods.GetEmberApiVersion()); *@
            await rm.CompileAllScriptsInFolderAndSaveToDB(userName: "Gilles", currentApiVersion: EmberMethods.GetEmberApiVersion());

            isWorking = false;
            StateHasChanged();

            await LoadDashBoardData();
        }
        catch (Exception e)
        {
            Console.WriteLine(e.ToString());
        }

    }

    private async Task HandleClearAllCaches()
    {
        try
        {
            await ScriptManager.ClearAllCaches();
            await LoadDashBoardData();
        }
        catch (Exception e)
        {
            Console.WriteLine(e.ToString());
        }
    }
    private async Task HandleDeleteAllScripts()
    {
        @* await ScriptManager.EnsureDeletedCreated(); *@
        await ScriptManager.DeleteAllData();
        await LoadDashBoardData();
    }
}