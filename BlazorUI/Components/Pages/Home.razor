                        </td>
                    </tr>
                    <tr>
                        <td class="ps-4">
                            <i class="bi bi-file-code text-primary"></i>
                            VaccineScript
                        </td>
                        <td>
                            <span class="badge bg-info">Action</span>
                        </td>
                        <td>v6</td>
                        <td>
                            <span class="badge bg-success">Compiled</span>
                        </td>
                        <td>5 hours ago</td>
                        <td class="text-end pe-4">
                            <div class="action-buttons justify-content-end">
                                <button class="btn btn-sm btn-outline-primary btn-icon" title="View">
                                    <i class="bi bi-eye"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-success btn-icon" title="Execute">
                                    <i class="bi bi-play-fill"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger btn-icon" title="Delete">
