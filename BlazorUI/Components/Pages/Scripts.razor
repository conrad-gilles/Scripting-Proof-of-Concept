@page "/scripts"
@rendermode InteractiveServer
@using System.Text.RegularExpressions
@using BlazorUI.Helpers
@using BlazorUI.Services
@using BlazorUI.TotalExecutions
@using Ember.Scripting
@* @using Ember.Scripting.ScriptMethods *@
@using Ember.Simulation
@using Microsoft.CodeAnalysis.Differencing
@using Microsoft.EntityFrameworkCore
@using Serilog
@using Ember.Scripting.Compilation

<PageTitle>Scripts</PageTitle>
<div class="page-container">
    @if (!_isEditing)
    {
        <div class="top-bar d-flex justify-content-between align-items-center mb-3">
            <h2 class="mb-0">All Scripts</h2>

            <div class="d-flex align-items-center gap-3">
                @* @if (_currentApiVersion > 0)
                { *@
                @* <div class="d-flex align-items-center gap-2">
                        <label for="versionSelect" class="form-label mb-0 fw-bold text-nowrap">Compile and Execute API
                            Version:</label>
                            <select id="versionSelect" class="form-select w-auto" style="min-width: 70px;"
                                    @bind="_selectedApiVersion" @bind:after="OnVersionChanged">
                                @for (int i = _currentApiVersion; i >= 1; i--)
                                {
                                    <option value="@i">V@(i)</option>
                                }
                            </select>
                        </div> *@
                @* } *@
                <a href="/create" class="btn btn-primary text-nowrap">
                    <i class="bi bi-plus-circle"></i> New Script
                </a>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                @if (_isLoading)
                {
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2">Loading scripts...</p>
                    </div>
                }
                else if (_scriptsList == null || !_scriptsList.Any())
                {
                    <div class="empty-state">
                        <i class="bi bi-file-code"></i>
                        <h4>No scripts found</h4>
                        <p>Create your first C# script to get started.</p>
                    </div>
                }
                else
                {
                    <div class="table-container">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Script Name</th>
                                    <th>Type</th>
                                    <th>Min API Version</th>
                                    <th>Created At</th>
                                    <th>Last edit</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var script in _scriptsList)
                                {
                                    <tr>
                                        <td><i class="bi bi-file-code text-primary"></i> @script.ScriptName</td>
                                        <td>
                                            @if (script.ScriptType != null && script.ScriptType.Contains("Action"))
                                            {
                                                <span class="badge bg-info">Action</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark">Condition</span>
                                            }
                                        </td>
                                        <td>v@(script.ScriptApiVersion)</td>
                                        <td>@(script.CreatedAt.ToString("MM-dd HH:mm") ?? "N/A")</td>
                                        @if ((script.ModifiedAt!.Value - script.CreatedAt).TotalSeconds <= 1)
                                        {
                                            <td>No Edit</td>
                                        }
                                        else
                                        {
                                            <td>@(script.ModifiedAt?.ToString("MM-dd HH:mm") ?? "N/A")</td>
                                        }
                                        <td>
                                            <div class="action-buttons">
                                                <button class="btn btn-sm btn-outline-success btn-icon"
                                                        @onclick="async () => await ExecuteScript(script.Id)" title="Execute">
                                                    <i class="bi bi-play-fill"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-primary btn-icon"
                                                        @onclick="async () => await EditScript(script.Id)" title="Edit">
                                                    <i class="bi bi-pencil-square"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-success btn-icon"
                                                        @onclick="async () => await CompileScript(script.Id)">
                                                    <i class="bi bi-hammer"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger btn-icon"
                                                        @onclick="async () => await DeleteScript(script.Id)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="d-flex flex-column" style="height: calc(100vh - 40px); overflow: hidden;">
            <div class="top-bar d-flex justify-content-between align-items-center mb-3 flex-shrink-0">
                <h2 class="mb-0">Edit Script: @_scriptName</h2>

                <div class="d-flex gap-2">
                    <button class="btn btn-outline-info" @onclick="async () => await Validate()!"
                            disabled="@(_editorHelper?.IsBusy ?? false)">
                        <i class="bi bi-check-circle"></i> Validate
                    </button>
                    @* <button class="btn btn-outline-warning" @onclick="() => _editorHelper?.Compile(_scriptCode)!"
                                disabled="@(_editorHelper?.IsBusy ?? false)">
                            <i class="bi bi-hammer"></i> Compile
                        </button> *@
                    <button class="btn btn-outline-primary" @onclick="async () => await Execute()"
                            disabled="@(_editorHelper?.IsBusy ?? false)">
                        <i class="bi bi-play-circle"></i> Execute
                    </button>
                    <select class="form-select" style="width: auto; min-width: 180px;" @bind="SelectedMethod"
                            disabled="@(_editorHelper?.IsBusy ?? false)">
                        <option value="" disabled>Select a method...</option>
                        @foreach (var method in PredefinedMethods)
                        {
                            <option value="@method">@method</option>
                        }
                    </select>
                    <button class="btn btn-success"
                            @onclick="async () => await _editorHelper?.Save(_currentScriptId, _scriptCode)!" //pobably bugs
                            because of giving scriptcode instead of reading from monaco
                            disabled="@(_editorHelper?.IsBusy ?? false)">
                        <i class="bi bi-save"></i> Save
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="CancelEditing">
                        <i class="bi bi-arrow-left"></i> Cancel
                    </button>
                </div>
            </div>

            @* <MonacoEditor @ref="_editor" EditorId="edit-monaco-editor" InitialCode="@_scriptCode" /> *@
            <MonacoEditor @ref="_editor" EditorId="edit-monaco-editor" InitialCode="@_scriptCode"
                          OnCodeChanged="() => _editorHelper?.SetErrorsInEditorAsync()!" />


            <div
                style="height: @(Console.IsExpanded ? "300px" : "40px"); transition: height 0.3s ease-in-out; flex-shrink: 0;">
            </div>
        </div>
    }

    <FakeTerminal />
    <Popup @ref="myPopup" />
</div>

@code {
    private IScriptManagerExtended ScriptManager => ScriptManagerAccessor.Current;
    private EmberInternalFacade EmberInternalFacade => EmberInternalFacadeAccessor.Current;
    private List<CustomerScript> _scriptsList = new();
    private Popup myPopup = default!;
    private bool _isLoading = true;

    private bool _isEditing = false;
    @* private int _currentApiVersion = 0;
    private int _selectedApiVersion = 0; *@
    private string SelectedMethod = "";
    private List<string> PredefinedMethods = ["Standard"];

    // Component References
    private MonacoEditor _editor = default!;
    private MonacoEditorHelper _editorHelper = default!;

    private string _scriptName = string.Empty;
    private int _minApiVersion = 6;
    private string _scriptCode = string.Empty;
    private Guid _currentScriptId;
    protected override async Task OnInitializedAsync()
    {
        @* _currentApiVersion = ScriptManager.GetRunningApiVersion();
        _selectedApiVersion = _currentApiVersion; *@
        await LoadScripts();
    }

    public async Task Validate()
    {
        ValidationRecord? vali = await _editorHelper.Validate();
        if (vali != null)
        {
            List<string> methods = ["Standard"];
            if (vali.methods != null)
            {
                foreach (var method in vali.methods)
                {
                    methods.Add(method.Name);
                }

            }
            PredefinedMethods = methods;
        }
    }
    public async Task Execute()
    {
        string? methodName = null;
        if (SelectedMethod != "Standard" && SelectedMethod != "")
        {
            methodName = SelectedMethod;
        }
        await _editorHelper?.Execute(methodName: methodName)!;
    }

    // We instantiate the Helper object when the MonacoEditor reference actually exists.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            if (_isEditing && _editorHelper == null && _editor != null)
            {
                _editorHelper = new MonacoEditorHelper(ScriptManagerAccessor.Current, EmberInternalFacadeAccessor.Current, _editor,
Console, myPopup)
                {
                    ScriptName = _scriptName,
                    CurrentScriptId = _currentScriptId
                };
                StateHasChanged();
            }

            if (_isEditing)
            {
                // Tell Monaco to recalculate its theme/layout when the tab renders
                // Using "edit-monaco-editor" because that's the EditorId you passed to the component
                await JSRuntime.InvokeVoidAsync("window.monacoEditor.refreshTheme", "edit-monaco-editor");
            }
        }
        catch (Exception e)
        {
            Console.LogException(e);
            myPopup.CreateErrorPopup(e.GetType().Name, e.Message);
        }
    }

    private async Task CancelEditing()
    {
        try
        {

            _isEditing = false;
            _editorHelper = null!;
            await LoadScripts();
        }
        catch (Exception e)
        {
            Console.LogException(e);
            myPopup.CreateErrorPopup(e.GetType().Name, e.Message);
        }
    }

    @* private async Task OnVersionChanged()
    {
        try
        {
            ServiceCollection services2 = new ServiceCollection();

            LoggerForScripting? logger = new LoggerForScripting();
            Log.Debug("Sandbox launched.");

            services2 = new ServiceCollection();
            services2.AddLogging(builder =>
            {
                builder.AddSerilog(dispose: true);
            });

            services2.AddDbContextFactory<EFModeling.EntityProperties.FluentAPI.Required.ScriptDbContext>();
            services2.AddSingleton<IUserSession, Sandbox.SandBoxUserSession>();

            ScriptingServiceCollectionExtensions.AddEmberScripting(services2, EmberMethods.GetReferences(),
                EmberMethods.GetEmberApiVersion(testingDiffrentVersion: _selectedApiVersion));

            var provider2 = services2.BuildServiceProvider();

            ScriptManager = provider2.GetRequiredService<ISccriptManagerDeleteAfter>();
            Console.Log($"User selected API Version: {_selectedApiVersion}");

            await LoadScripts();
        }
        catch (Exception e)
        {
            Console.LogException(e);
            myPopup.CreateErrorPopup(e.GetType().Name, e.Message);
        }
    } *@

    private async Task LoadScripts()
    {
        _isLoading = true;
        try
        {
            _scriptsList = await ScriptManager.ListScripts(null!, includeCaches: false);
        }
        catch (Exception e)
        {
            Console.LogException(e);
            myPopup.CreateErrorPopup(e.GetType().Name, e.Message);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
         
    }

    private async Task ExecuteScript(Guid id)
    {
        try
        {
            object ar = await EmberInternalFacade.ExecuteScript(id, TestHelper.GetContext(), "Default");
            Console.Log(ar.ToString()!);
            myPopup.CreateNormalPopup("Success", ar.ToString()!);
        }
        catch (Exception e)
        {
            Console.LogException(e);
            myPopup.CreateErrorPopup(e.GetType().Name, e.Message);
        }
    }

    private async Task CompileScript(Guid id)
    {
        try
        {
            await ScriptManager.CompileScript(id);
            await LoadScripts();
        }
        catch (Exception e)
        {
            Console.LogException(e);
            myPopup.CreateErrorPopup(e.GetType().Name, e.Message);
        }
    }

    private async Task DeleteScript(Guid id)
    {
        try
        {

            await ScriptManager.DeleteScript(id);
            await LoadScripts();
        }
        catch (Exception e)
        {
            Console.LogException(e);
            myPopup.CreateErrorPopup(e.GetType().Name, e.Message);
        }
    }

    public static string GetTemplate()
    {
        var resourceName = "BlazorUI.src.ScriptTemplate.cs";
        var assembly = System.Reflection.Assembly.GetExecutingAssembly();
        using (Stream stream = assembly.GetManifestResourceStream(resourceName)!)
        {
            if (stream == null) return "// Template missing";
            using (StreamReader reader = new StreamReader(stream))
            {
                return reader.ReadToEnd();
            }
        }
    }

    private async Task EditScript(Guid id)
    {
        try
        {
            CustomerScript script = await ScriptManager.GetScript(id);

            if (script != null)
            {
                _currentScriptId = id;
                _scriptName = script.ScriptName!;
                _scriptCode = script.SourceCode ?? string.Empty;

                _isEditing = true;
                StateHasChanged();
                await LoadScripts();
            }
        }
        catch (Exception e)
        {
            Console.LogException(e);
            myPopup.CreateErrorPopup(e.GetType().Name, e.Message);
        }
    }
}