@page "/scripts"
@rendermode InteractiveServer
@using Ember.Scripting
@using BlazorUI.TotalExecutions
@using BlazorUI.Services
@using BlazorUI.Helpers
@using Microsoft.CodeAnalysis.Differencing
@using System.Text.RegularExpressions
@using Serilog
@inject ConsoleService Console
@inject ISccriptManagerDeleteAfter ScriptManager

<PageTitle>Scripts</PageTitle>
<div class="page-container">
    @if (!isEditing)
    {
        <div class="top-bar d-flex justify-content-between align-items-center mb-3">
            <h2 class="mb-0">All Scripts</h2>

            <div class="d-flex align-items-center gap-3">
                @if (currentApiVersion > 0)
                {
                    <div class="d-flex align-items-center gap-2">
                        <label for="versionSelect" class="form-label mb-0 fw-bold text-nowrap">Compile and Execute API
                            Version:</label>
                            <select id="versionSelect" class="form-select w-auto" style="min-width: 70px;"
                                    @bind="selectedApiVersion" @bind:after="OnVersionChanged">
                                @for (int i = currentApiVersion; i >= 1; i--)
                                {
                                    <option value="@i">V@(i)</option>
                                }
                            </select>
                        </div>
                    }
                    <a href="/create" class="btn btn-primary text-nowrap">
                        <i class="bi bi-plus-circle"></i> New Script
                    </a>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    @if (isLoading)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p class="mt-2">Loading scripts...</p>
                        </div>
                    }
                    else if (ScriptsList == null || !ScriptsList.Any())
                    {
                        <div class="empty-state">
                            <i class="bi bi-file-code"></i>
                            <h4>No scripts found</h4>
                            <p>Create your first C# script to get started.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-container">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Script Name</th>
                                        <th>Type</th>
                                        <th>Min API Version</th>
                                        <th>Created At</th>
                                        <th>Last edit</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var script in ScriptsList)
                                    {
                                        <tr>
                                            <td><i class="bi bi-file-code text-primary"></i> @script.ScriptName</td>
                                            <td>
                                                @if (script.ScriptType != null && script.ScriptType.Contains("Action"))
                                                {
                                                    <span class="badge bg-info">Action</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning text-dark">Condition</span>
                                                }
                                            </td>
                                            <td>v@(script.MinApiVersion)</td>
                                            <td>@(script.CreatedAt?.ToString("MM-dd HH:mm") ?? "N/A")</td>
                                            @if ((script.ModifiedAt!.Value - script.CreatedAt!.Value).TotalSeconds <= 1)
                                            {
                                                <td>No Edit</td>
                                            }
                                            else
                                            {
                                                <td>@(script.ModifiedAt?.ToString("MM-dd HH:mm") ?? "N/A")</td>
                                            }
                                            <td>
                                                <div class="action-buttons">
                                                    <button class="btn btn-sm btn-outline-success btn-icon"
                                                            @onclick="() => ExecuteScript(script.Id)" title="Execute">
                                                        <i class="bi bi-play-fill"></i>
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-primary btn-icon"
                                                            @onclick="() => EditScript(script.Id)" title="Edit">
                                                        <i class="bi bi-pencil-square"></i>
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-success btn-icon"
                                                            @onclick="() => CompileScript(script.Id)">
                                                        <i class="bi bi-hammer"></i>
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-danger btn-icon"
                                                            @onclick="() => DeleteScript(script.Id)">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        }
    else
        {
            <div class="d-flex flex-column" style="height: calc(100vh - 40px); overflow: hidden;">
                <div class="top-bar d-flex justify-content-between align-items-center mb-3 flex-shrink-0">
                    <h2 class="mb-0">Edit Script: @_scriptName</h2>

                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-info" @onclick="() => _editorHelper?.HandleValidate()!"
                                disabled="@(_editorHelper?.IsBusy ?? false)">
                            <i class="bi bi-check-circle"></i> Validate
                        </button>
                        <button class="btn btn-outline-warning" @onclick="() => _editorHelper?.HandleCompile()!"
                                disabled="@(_editorHelper?.IsBusy ?? false)">
                            <i class="bi bi-hammer"></i> Compile
                        </button>
                        <button class="btn btn-success" @onclick="() => _editorHelper?.HandleSave()!"
                                disabled="@(_editorHelper?.IsBusy ?? false)">
                            <i class="bi bi-save"></i> Save
                        </button>
                        <button class="btn btn-outline-secondary" @onclick="CancelEditing">
                            <i class="bi bi-arrow-left"></i> Cancel
                        </button>
                    </div>
                </div>

                <MonacoEditor @ref="_editor" EditorId="edit-monaco-editor" InitialCode="@_scriptCode" />

                <div
                    style="height: @(Console.IsExpanded ? "300px" : "40px"); transition: height 0.3s ease-in-out; flex-shrink: 0;">
                </div>
            </div>
        }

        <FakeTerminal />
    </div>

@code {
    private List<CustomerScript> ScriptsList = new();
    private bool isLoading = true;

    private bool isEditing = false;
    private int currentApiVersion = 0;
    private int selectedApiVersion = 0;

    // Component References
    private MonacoEditor _editor = default!;
    private MonacoEditorHelper _editorHelper = default!;

    private string _scriptName = string.Empty;
    private int _minApiVersion = 6;
    private string _scriptCode = string.Empty;
    private Guid _currentScriptId;

    public string DefaultScript = GetTemplate();

    protected override async Task OnInitializedAsync()
    {
        currentApiVersion = ScriptManager.GetRunningApiVersion();
        selectedApiVersion = currentApiVersion;
        await LoadScripts();
    }

    // We instantiate the Helper object when the MonacoEditor reference actually exists.
    protected override void OnAfterRender(bool firstRender)
    {
        if (isEditing && _editorHelper == null && _editor != null)
        {
            _editorHelper = new MonacoEditorHelper(ScriptManager, _editor, Console)
            {
                ScriptName = _scriptName,
                CurrentScriptId = _currentScriptId
            };
            StateHasChanged();
        }
    }

    private void CancelEditing()
    {
        isEditing = false;
        _editorHelper = null!;
    }

    private async Task OnVersionChanged()
    {
        ServiceCollection services2 = new ServiceCollection();

        LoggerForScripting? logger = new LoggerForScripting();
        Log.Debug("Sandbox launched.");

        services2 = new ServiceCollection();
        services2.AddLogging(builder =>
        {
            builder.AddSerilog(dispose: true);
        });

        ScriptingServiceCollectionExtensions.AddEmberScripting(services2, EmberMethods.GetReferences(),
            EmberMethods.GetEmberApiVersion(testingDiffrentVersion: selectedApiVersion));

        using var provider2 = services2.BuildServiceProvider();

        ScriptManager = provider2.GetRequiredService<ISccriptManagerDeleteAfter>();
        Console.Log($"User selected API Version: {selectedApiVersion}");

        await LoadScripts();
    }

    private async Task LoadScripts()
    {
        isLoading = true;
        try
        {
            ScriptsList = await ScriptManager.ListScripts(null!, includeCaches: false);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ExecuteScript(Guid id)
    {
        try
        {
            Console.Log("Test if it prints");
            EmberMethods em = new EmberMethods(ScriptManager);
            CustomerScript script = await ScriptManager.GetScript(id);
            var ctx = await em.GetTestingContext<GeneratorContextV4.GeneratorContext>(autoDetectFromScript: script);
            object resultObj = await ScriptManager.ExecuteScriptById(id, ctx);

            if (typeof(bool).IsAssignableFrom(resultObj.GetType()))
            {
                Console.Log("Script returned a bool: " + resultObj.ToString());
            }
            else if (typeof(ActionResultSF).IsAssignableFrom(resultObj.GetType()))
            {
                Console.Log("Script returned an ActionResult: " + resultObj.ToString());
            }
            else
            {
                Console.Log("Script was neither returned a bool nor an ActionResultBaseClass, it was a: " +
resultObj.GetType().ToString());
            }
            TotalExecutions.IncrementTotalExecutions();
            await LoadScripts();
        }
        catch (Exception e)
        {
            Console.Log(e.ToString());
        }
    }

    private async Task CompileScript(Guid id)
    {
        try
        {
            await ScriptManager.CompileScript(id);
            await LoadScripts();
        }
        catch (Exception e)
        {
            Console.Log(e.ToString());
        }
    }

    private async Task DeleteScript(Guid id)
    {
        await ScriptManager.DeleteScript(id);
        await LoadScripts();
    }

    public static string GetTemplate()
    {
        var resourceName = "BlazorUI.src.ScriptTemplate.cs";
        var assembly = System.Reflection.Assembly.GetExecutingAssembly();
        using (Stream stream = assembly.GetManifestResourceStream(resourceName)!)
        {
            if (stream == null) return "// Template missing";
            using (StreamReader reader = new StreamReader(stream))
            {
                return reader.ReadToEnd();
            }
        }
    }

    private async Task EditScript(Guid id)
    {
        try
        {
            CustomerScript script = await ScriptManager.GetScript(id);

            if (script != null)
            {
                _currentScriptId = id;
                _scriptName = script.ScriptName!;
                _scriptCode = script.SourceCode ?? string.Empty;

                isEditing = true;
                StateHasChanged();
                await LoadScripts();
            }
        }
        catch (Exception ex)
        {
            Console.Log($"Failed to load script: {ex.Message}");
        }
    }
}