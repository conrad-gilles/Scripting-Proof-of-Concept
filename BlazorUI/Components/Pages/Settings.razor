@page "/settings"
@rendermode InteractiveServer

@using BlazorUI.Settings
@using Ember.Scripting.ScriptMethods
@using Serilog
<PageTitle>Settings</PageTitle>

<div class="top-bar mb-4">
    <h2 class="mb-0">Settings</h2>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-white py-3">
        <h5 class="mb-0"><i class="bi bi-gear me-2"></i> System Preferences</h5>
    </div>
    <div class="card-body">
        
        <!-- Use Console Switch -->
        <div class="form-check form-switch fs-5 mb-3">
            <input class="form-check-input cursor-pointer" type="checkbox" id="useConsole"
                   @bind="AppSettings.UseConsole">
                <label class="form-check-label" for="useConsole">Enable Console Output</label>
            </div>

            <!-- Use Popup Switch -->
            <div class="form-check form-switch fs-5 mb-3">
                <input class="form-check-input cursor-pointer" type="checkbox" id="usePopup" @bind="AppSettings.UsePopup">
                    <label class="form-check-label" for="usePopup">Enable Action Popups</label>
                </div>

                <!-- Print Detailed in Console Switch -->
                <div class="form-check form-switch fs-5 mb-3">
                    <input class="form-check-input cursor-pointer" type="checkbox" id="printDetailed"
                           @bind="AppSettings.PrintDetailedInConsole">
                        <label class="form-check-label" for="printDetailed">Print Detailed Logs in Console</label>
                    </div>
                    <div class="mb-3 mt-3">
                        <label class="form-label fs-5 mb-2" for="emberVersion">Ember API Version</label>
                        <select class="form-select cursor-pointer" style="max-width: 250px;" id="emberVersion"
                                @bind="_selectedApiVersion" @bind:after="async () => await UpdateApiVersion()">
                            @for (int i = 1; i <= EmberMethods.GetEmberApiVersion(); i++)
                            {
                                <option value="@i">Version @i</option>
                            }
                        </select>
                    </div>

                </div>
            </div>
<FakeTerminal />
<Popup @ref="myPopup" />
@code {
    private IScriptManagerDeleteAfter ScriptManager => ScriptManagerAccessor.Current;
    private int _selectedApiVersion = AppSettings.EmberApiVersion;
    private Popup myPopup = default!;
    public async Task UpdateApiVersion()
    {

        try
        {
            ServiceCollection services2 = new ServiceCollection();

            LoggerForScripting? logger = new LoggerForScripting();

            services2 = new ServiceCollection();
            services2.AddLogging(builder =>
            {
                builder.AddSerilog(dispose: true);
            });

            services2.AddDbContextFactory<EFModeling.EntityProperties.FluentAPI.Required.ScriptDbContext>();
            services2.AddScoped<IUserSession, Sandbox.SandBoxUserSession>();
            services2.AddScoped<EmberInternalFacade>();
            ScriptingServiceCollectionExtensions.AddEmberScripting(services2, EmberMethods.GetReferences(),
                EmberMethods.GetEmberApiVersion(testingDiffrentVersion: _selectedApiVersion));

            var provider2 = services2.BuildServiceProvider();

            ScriptManagerAccessor.Current = provider2.GetRequiredService<IScriptManagerDeleteAfter>();
            EmberInternalFacadeAccessor.Current = provider2.GetRequiredService<EmberInternalFacade>();
            Console.Log($"User selected API Version {_selectedApiVersion}");
            AppSettings.EmberApiVersion = _selectedApiVersion;

            
            @* await LoadScripts(); *@
        }
        catch (Exception e)
        {
            Console.LogException(e);
            myPopup.CreateErrorPopup(e.GetType().Name, e.Message);
        }
    }
        
}