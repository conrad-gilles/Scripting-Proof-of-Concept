    private async Task HandleCompile()
    {
        _isBusy = true;
        var code = await JS.InvokeAsync<string>("monacoEditor.getValue");

        // Clear old red lines first
        await JS.InvokeVoidAsync("monacoEditor.clearErrors");

        Console.Log($"Compiling '{_scriptName}'...");

        try
        {
            await ScriptManager.CreateScript(code);
            Console.Log("Compilation successful, script was created and inserted into the DB.");
        }
        catch (Exception ex)
        {
            Console.Log($"Compilation Failed: {ex.Message}");

            // Parse the error string to find Line and Col numbers
            var errorsList = new List<object>();

            // Regex looks for "Line X, Col Y: ErrorMessage"
            var regex = new Regex(@"Line (\d+), Col (\d+): (.*)");
            var matches = regex.Matches(ex.Message);

            foreach (Match match in matches)
            {
                if (match.Success)
                {
                    errorsList.Add(new
                    {
                        line = int.Parse(match.Groups[1].Value),
                        column = int.Parse(match.Groups[2].Value),
                        message = match.Groups[3].Value
                    });
                }
            }

            // If we found parseable errors, send them to Javascript
            if (errorsList.Any())
            {
                await JS.InvokeVoidAsync("monacoEditor.setErrors", errorsList);
            }
        }
        finally
        {
            _isBusy = false;
        }
    }



    private async Task HandleSave() //todo
