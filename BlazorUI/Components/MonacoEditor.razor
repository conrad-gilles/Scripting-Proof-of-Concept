@using Microsoft.JSInterop
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="card border-0 flex-grow-1" style="min-height: 0;">
    <div class="card-body p-0"
         style="border-radius: 10px; overflow: hidden; background: #1e1e1e; color: #d4d4d4; text-align: left; height: 100%;">
        <div id="@EditorId" style="height: 100%; width: 100%;"></div>
    </div>
</div>

@code {
    // 1. Generate a unique ID for every editor instance
    [Parameter] public string EditorId { get; set; } = $"monaco-editor-{Guid.NewGuid():N}";
    [Parameter] public string InitialCode { get; set; } = string.Empty;
    [Parameter] public EventCallback OnCodeChanged { get; set; }

    private bool _editorReady = false;
    private DotNetObjectReference<MonacoEditor>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("monacoEditor.initialize", EditorId, InitialCode, "csharp", _dotNetRef);
            _editorReady = true;
        }
    }

    [JSInvokable]
    public async Task HandleCodeChange()
    {
        if (OnCodeChanged.HasDelegate)
        {
            await OnCodeChanged.InvokeAsync();
        }
    }

    // 2. Pass 'EditorId' into all JS invocations
    public async Task<string> GetValueAsync()
    {
        if (!_editorReady) return string.Empty;
        return await JS.InvokeAsync<string>("monacoEditor.getValue", EditorId);
    }

    public async Task SetValueAsync(string value)
    {
        if (_editorReady) await JS.InvokeVoidAsync("monacoEditor.setValue", EditorId, value);
        else InitialCode = value;
    }

    public async Task ClearErrorsAsync()
    {
        if (_editorReady) await JS.InvokeVoidAsync("monacoEditor.clearErrors", EditorId);
    }

    public async Task SetErrorsAsync(List<object> errors)
    {
        if (_editorReady && errors.Any())
        {
            await JS.InvokeVoidAsync("monacoEditor.setErrors", EditorId, errors);
        }
    }

    public async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        if (_editorReady)
        {
            try
            {
                await JS.InvokeVoidAsync("monacoEditor.dispose", EditorId);
            }
            catch (Microsoft.JSInterop.JSDisconnectedException)
            {
                // The browser has disconnected, so the JS environment is already gone.
                // We can safely ignore this.
            }
            catch (TaskCanceledException)
            {
                // Ignore cancelled tasks during disposal
            }
        }
    }
}

