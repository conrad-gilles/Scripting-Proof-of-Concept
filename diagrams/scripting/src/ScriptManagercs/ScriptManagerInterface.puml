@startuml
interface IScriptManager {
    CreateScript(sourceCode:string, userName:string, apiVersion:int) : Task<Guid>
    UpdateScript(scriptId:Guid, newSourceCode:string, userName:string, apiVersion:int) : Task
    DeleteScript(scriptId:Guid) : Task
    GetScript(scriptId:Guid, includeCaches:bool) : Task<CustomerScript>
    ListScripts(filters:CustomerScriptFilter, includeCaches:bool) : Task<List<CustomerScript>>
    CompileScript(scriptId:Guid, targetApiVersion:int) : Task
    CompileAllScripts() : Task
    RecompileScript(scriptId:Guid) : Task
    ValidateScript(sourceCode:string) : Task<string>
    GetCompilationErrors(scriptId:Guid, apiVersion:int) : Task<string>
    ExecuteActionScript(scriptId:Guid, context:GeneratorContext, apiVersion:int) : Task<ActionResultBaseClass>
    ExecuteConditionScript(scriptId:Guid, context:GeneratorContext, apiVersion:int) : Task<bool>
    ExecuteScriptById(scriptId:Guid, context:GeneratorContext, currentApiVersion:int) : Task<object>
    GetCompiledCache(scriptId:Guid, currentApiVersion:int) : Task<byte[]>
    ClearScriptCache(scriptId:Guid) : Task
    ClearAllCaches() : Task
    PrecompileForApiVersion() : Task
    GetActiveApiVersions() : Task<List<int>>
    GetRecentApiVersion() : Task<int>
    GetScriptCompatibility(scriptId:Guid) : Task<int>
    CheckVersionCompatibility(scriptId:Guid, targetApiVersion:int) : Task<bool>
    RegisterEmberInstance(instanceId:Guid, emberVersion:string, apiVersion:int) : Task
    DetectDuplicates() : Task<(List<Guid> scriptGUIDs, Dictionary<Guid, int> cacheGUIDs)>
    RemoveDuplicates() : Task
    CleanupOrphanedCaches() : Task
    GetScriptExecutionHistory(scriptId:Guid) : Task
    GetCompilationStatistics() : Task
    HealthCheck() : Task
    GetScriptMetadata(scriptId:Guid) : Task<string>
    GetUserName() : string
}
class CustomerScriptFilter {
    + ScriptName : string?
    + ScriptType : string?
    + SourceCode : string?
    + MinApiVersion : int?
    + CreatedAt : DateTime?
    + ModifiedAt : DateTime?
    + CreatedBy : string?
    + CustomerScriptFilter(scriptName:string?, scriptType:string?, sourceCode:string?, minApiVersion:int?, createdAt:DateTime?, modifiedAt:DateTime?, createdBy:string?)
}
@enduml
