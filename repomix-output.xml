<file path="BlazorUI/Components/MonacoEditor.razor">
@using Microsoft.JSInterop
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="card border-0 flex-grow-1" style="min-height: 0;">
    <div class="card-body p-0" style="border-radius: 10px; overflow: hidden; background: #1e1e1e; height: 100%;">
        <!-- Note: We make the ID dynamic in case you ever put TWO editors on one page -->
        <div id="@EditorId" style="height: 100%; width: 100%;"></div>
    </div>
</div>

@code {
    [Parameter]
    public string EditorId { get; set; } = "monaco-editor-container";

    [Parameter]
    public string InitialCode { get; set; } = string.Empty;

    private bool _editorReady = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync(
                "monacoEditor.initialize",
                EditorId,
                InitialCode,
                "csharp"
            );
            _editorReady = true;
        }
    }

    // Public method so the parent page can get the code
    public async Task<string> GetValueAsync()
    {
        if (!_editorReady) return string.Empty;
        return await JS.InvokeAsync<string>("monacoEditor.getValue");
    }

    // Add this to MonacoEditor.razor
    public async Task SetValueAsync(string value)
    {
        if (_editorReady)
        {
            await JS.InvokeVoidAsync("monacoEditor.setValue", value);
        }
        else
        {
            // If the editor hasn't loaded yet, store it in InitialCode so it gets used when OnAfterRender runs
            InitialCode = value;
        }
    }

    // Public method to clear errors
    public async Task ClearErrorsAsync()
    {
        if (_editorReady)
        {
            await JS.InvokeVoidAsync("monacoEditor.clearErrors");
        }
    }

    // Public method to set errors
    public async Task SetErrorsAsync(List<object> errors)
    {
        if (_editorReady && errors.Any())
        {
            await JS.InvokeVoidAsync("monacoEditor.setErrors", errors);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_editorReady)
            await JS.InvokeVoidAsync("monacoEditor.dispose");
    }
}
</file>

<file path="BlazorUI/Components/Pages/Cache.razor">
@page "/cache"
@rendermode InteractiveServer
@using BlazorUI.Services
@using Ember.Scripting
@inject ISccriptManagerDeleteAfter ScriptManager
@inject ConsoleService Console

<PageTitle>Cache Management</PageTitle>

<div class="page-container">
    <div class="top-bar d-flex justify-content-between align-items-center mb-4">
        <h2>Cache Management</h2>
        <button class="btn btn-outline-danger" @onclick="HandleClearAll">
            <i class="bi bi-trash"></i> Clear All Caches
        </button>
    </div>

    @if (caches == null || !caches.Any())
    {
        <div class="empty-state">
            <i class="bi bi-database"></i>
            <h4>No compiled caches found</h4>
            <p>Compile some scripts to see them appearing here.</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Script Name</th>
                            <th>API Version</th>
                            <th>Status</th>
                            <th>Compilation Date</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cache in caches)
                        {
                            <tr>
                                <td class="ps-4">
                                    <strong>@cache.CustomerScript?.ScriptName</strong>
                                    <br />
                                    <small class="text-muted">ID: @cache.ScriptId</small>
                                </td>
                                <td><span class="badge bg-info">v @cache.ApiVersion</span></td>
                                <td>
                                    @if (cache.CompilationSuccess)
                                    {
                                        <span class="badge bg-success">Success</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger" title="@cache.CompilationErrors">Failed</span>
                                    }
                                </td>
                                <td>@cache.CompilationDate.ToString("g")</td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-sm btn-outline-danger btn-icon" title="Delete this cache version"
                                            @onclick="() => HandleDeleteCache(cache)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    <FakeTerminal />
</div>

@code {
    private List<ScriptCompiledCache> caches = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadCaches();
    }

    private async Task LoadCaches()
    {
        // Fetch all caches from the database
        caches = await ScriptManager.GetAllCompiledScriptCaches();
        StateHasChanged();
    }

    private async Task HandleClearAll()
    {
        await ScriptManager.ClearAllCaches();
        await LoadCaches();
    }
    private async Task HandleDeleteCache(ScriptCompiledCache cache)
    {
        await ScriptManager.DeleteScriptCache(cache.ScriptId, cache.ApiVersion);
        await LoadCaches();
    }
}
</file>

